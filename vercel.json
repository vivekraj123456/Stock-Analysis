{
  "version": 2,
  "env": {
    "LIVE_REFRESH_INTERVAL_MS": "10000",
    "LIVE_CACHE_TTL_SECONDS": "10",
    "LIVE_MAX_QUOTE_AGE_MINUTES": "20",
    "ENABLE_NSE_QUOTES": "1",
    "NSE_TIMEOUT_SECONDS": "2.5",
    "YAHOO_BATCH_TIMEOUT_SECONDS": "2.5",
    "YAHOO_QUOTE_BATCH_SIZE": "50",
    "YAHOO_CHART_TIMEOUT_SECONDS": "2.5"
  },
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
